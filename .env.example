# Application
APP_NAME=opencli-admin
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-long-random-string

# Database
DATABASE_URL=sqlite+aiosqlite:///./opencli_admin.db
# DATABASE_URL=postgresql+asyncpg://opencli:opencli_secret@localhost:5432/opencli_admin

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# API Security (optional)
API_KEY_ENABLED=false
API_KEY=

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Webhooks
WEBHOOK_SECRET=change-me-webhook-secret

# Postgres (if using docker-compose postgres profile)
POSTGRES_DB=opencli_admin
POSTGRES_USER=opencli
POSTGRES_PASSWORD=opencli_secret

# Timezone
DEFAULT_TIMEZONE=UTC
